  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "const utils = {",
          "    getRelativeDate: function (daysToShift, baseDateString = null) {",
          "        const baseDate = baseDateString ? new Date(baseDateString) : new Date();",
          "        baseDate.setDate(baseDate.getDate() + daysToShift);",
          "        return baseDate.toISOString().split('T')[0];",
          "    },",
          "",
          "    getRandomAmenity: function () {",
          "        const amenities = [\"Breakfast\", \"Late Checkout\", \"Extra Towels\", \"Parking\", \"Baby Cot\"];",
          "        return amenities[Math.floor(Math.random() * amenities.length)];",
          "    },",
          "",
          "    validateResponseStatus: function (statusCode) {",
          "        pm.test(\"Status code is \" + statusCode, function () {",
          "            pm.response.to.have.status(statusCode);",
          "        });",
          "    },",
          "",
          "    validateBookingData: function (actual, expected) {",
          "        pm.test(\"Booking data matches expected values\", function () {",
          "            pm.expect(actual.firstname).to.eql(expected.firstname);",
          "            pm.expect(responseData.lastname).to.eql(expected.lastname);",
          "            pm.expect(actual.totalprice).to.eql(expected.totalprice);",
          "            pm.expect(actual.depositpaid).to.eql(expected.depositpaid);",
          "            pm.expect(actual.additionalneeds).to.eql(expected.additionalneeds);",
          "            pm.expect(actual.bookingdates.checkin).to.eql(expected.bookingdates.checkin);",
          "            pm.expect(actual.bookingdates.checkout).to.eql(expected.bookingdates.checkout);",
          "        });",
          "    },",
          "",
          "    validateIdInList: function (list) {",
          "        pm.test(\"Created booking ID is present in the list\", function () {",
          "            const expectedId = Number(pm.environment.get(\"bookingId\"));",
          "            const idExists = list.some(item => item.bookingid === expectedId);",
          "            pm.expect(idExists).to.be.true;",
          "        });",
          "    }",
          "}",
          "",
          "pm.environment.set(\"sharedUtils\", `({",
          "    getRelativeDate: ${utils.getRelativeDate.toString()},",
          "    getRandomAmenity: ${utils.getRandomAmenity.toString()},",
          "    validateResponseStatus: ${utils.validateResponseStatus.toString()},",
          "    validateBookingData: ${utils.validateBookingData.toString()},",
          "    validateIdInList: ${utils.validateIdInList.toString()}",
          "})`);"
        ]
      }
